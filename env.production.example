# ══════════════════════════════════════════════════════════════════════
# Template .env untuk PRODUCTION (hosting).
#
# Cara pakai:
#   1. Copy ke server sebagai .env       → cp .env.production.example .env
#   2. Isi SEMUA baris bertanda "ISI INI" di bawah dengan nilai asli.
#   3. php artisan key:generate --force
#   4. php artisan config:cache && php artisan route:cache && php artisan view:cache
#
# JANGAN commit file .env (apapun isinya) ke git.
# ══════════════════════════════════════════════════════════════════════

APP_NAME="Yoza Rent Car"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ISI_INI_domain_anda.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# error/warning saja — jangan "debug" di production (mencegah kebocoran
# detail internal lewat log, dan log tidak membengkak percuma)
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ISI_INI_nama_database
DB_USERNAME=ISI_INI_user_db
DB_PASSWORD=ISI_INI_password_db

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Wajib true karena APP_URL sudah https — cookie sesi hanya dikirim lewat HTTPS
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
# Production sebaiknya redis (lebih stabil untuk worker jangka panjang
# dibanding "database"), lihat README bagian Queue.
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=ISI_INI_password_redis_jika_ada
REDIS_PORT=6379

# SMTP transaksional asli — JANGAN pakai "log"/mailtrap di production,
# nanti email ke pelanggan (konfirmasi, invoice, dst) tidak terkirim.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=ISI_INI_smtp_host
MAIL_PORT=587
MAIL_USERNAME=ISI_INI_smtp_username
MAIL_PASSWORD=ISI_INI_smtp_password
MAIL_FROM_ADDRESS="noreply@ISI_INI_domain_anda.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Reverb (WebSocket realtime chat) — generate dengan:
#   php artisan reverb:install   (jika belum pernah dijalankan)
REVERB_APP_ID=ISI_INI
REVERB_APP_KEY=ISI_INI
REVERB_APP_SECRET=ISI_INI
REVERB_HOST="ISI_INI_domain_anda.com"
REVERB_PORT=8080
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Google OAuth — dari Google Cloud Console, redirect URI harus
# https://ISI_INI_domain_anda.com/auth/google/callback
GOOGLE_CLIENT_ID=ISI_INI
GOOGLE_CLIENT_SECRET=ISI_INI
GOOGLE_REDIRECT_URI=https://ISI_INI_domain_anda.com/auth/google/callback

# Nomor WA ADMIN asli untuk terima pesanan — nilai contoh di
# .env.example BUKAN nomor production, WAJIB diganti.
PAYMENT_WA_NUMBER=ISI_INI_62xxxxxxxxxx
PAYMENT_TRANSFER_BANK=ISI_INI
PAYMENT_TRANSFER_REKENING=ISI_INI
PAYMENT_TRANSFER_ATAS_NAMA="ISI_INI"
PAYMENT_QRIS_IMAGE=payment/qris.png
